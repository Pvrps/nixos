+	/// Composite an image that has an alpha channel onto a checkerboard
+	/// background before quantisation.  Semi-transparent pixels are properly
+	/// alpha-composited so the checkerboard shows through, while fully
+	/// transparent pixels become the checkerboard colour directly.  The
+	/// resulting image is fully opaque, so no alpha reservation is needed
+	/// in the Sixel palette — all 256 slots are available for colours.
+	fn flatten_alpha(img: &DynamicImage) -> RgbImage {
+		// Checkerboard tile size in pixels.
+		const TILE: u32 = 8;
+		// Light and dark grey tiles — mid-tones visible against any content.
+		const LIGHT: [u8; 3] = [0xCC, 0xCC, 0xCC];
+		const DARK:  [u8; 3] = [0x88, 0x88, 0x88];
+
+		let rgba = img.to_rgba8();
+		let (w, h) = rgba.dimensions();
+
+		ImageBuffer::from_fn(w, h, |x, y| {
+			let px = rgba.get_pixel(x, y);
+			let a = px[3] as f32 / 255.0;
+
+			let bg = if ((x / TILE) + (y / TILE)) % 2 == 0 { LIGHT } else { DARK };
+
+			Rgb([
+				(a * px[0] as f32 + (1.0 - a) * bg[0] as f32).round() as u8,
+				(a * px[1] as f32 + (1.0 - a) * bg[1] as f32).round() as u8,
+				(a * px[2] as f32 + (1.0 - a) * bg[2] as f32).round() as u8,
+			])
+		})
+	}
+
